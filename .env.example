# @BotFather token for @HoodPredictBot
TELEGRAM_BOT_TOKEN=your_bot_token
BOT_USERNAME=HoodPredictBot

# xAI Grok — AI Auto-Trader & forecasts (https://console.x.ai)
XAI_API_KEY=your_xai_key
XAI_MODEL=grok-4.5

# Robinhood Chain (defaults to mainnet)
RPC_URL=https://rpc.mainnet.chain.robinhood.com
CHAIN_ID=4663
USE_TESTNET=false

# Contract addresses (auto-loaded from deployments-*.json if omitted)
# Mainnet collateral is USDG (Global Dollar)
FACTORY_ADDRESS=
USDC_ADDRESS=0x5fc5360D0400a0Fd4f2af552ADD042D716F1d168
ORACLE_ADAPTER_ADDRESS=

# WalletConnect project ID (https://cloud.reown.com) — for web wallet flows
WALLETCONNECT_PROJECT_ID=

# HoodPredict web app (bet signing UI)
WEB_APP_URL=https://hoodpredict.vercel.app

# Premium monetization — Stripe payment links
STRIPE_MONTHLY_LINK=https://buy.stripe.com/hoodpredict_monthly
STRIPE_YEARLY_LINK=https://buy.stripe.com/hoodpredict_yearly
PREMIUM_MONTHLY_USD=9.99
PREMIUM_YEARLY_USD=89
TRIAL_DAYS=7

# Admin Telegram user ID (for /grant after Stripe payment)
ADMIN_USER_ID=

# Database (SQLite local; use Supabase for production — see README)
# Encrypts custodial wallet keys at rest (use a long random string in production)
WALLET_ENCRYPTION_SECRET=

DB_PATH=data/hoodpredict.db
SUPABASE_URL=
SUPABASE_SERVICE_KEY=